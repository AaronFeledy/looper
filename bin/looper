#!/usr/bin/env bash
set -euo pipefail

# Resolve this script's real path even when invoked via a symlink chain.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  # If $SOURCE was a relative symlink, resolve it relative to its dir.
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
BIN_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
ROOT_DIR="$(cd "$BIN_DIR/.." >/dev/null 2>&1 && pwd)"

exec bun "$ROOT_DIR/src/main.ts" "$@"
